# 机器人 Token（从 @BotFather 获取）
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ========== 随机视频功能 ==========
# 收录视频的频道
CHANNEL_ID=@your_channel

# ========== 关键词转发链 ==========
# 监听的源频道（逗号分隔，支持 @用户名 和 -100xxx 数字ID）
SOURCE_CHANNELS=@channel1,@channel2

# 触发关键词（逗号分隔，不区分大小写，命中任意一个即触发）
KEYWORDS=关键词1,关键词2

# 接收到转发消息的目标机器人
TARGET_BOT=@target_bot_username

# 目标机器人回复后，转发到这个频道
DEST_CHANNEL=@your_channel
